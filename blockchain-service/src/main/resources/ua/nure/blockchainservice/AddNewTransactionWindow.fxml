<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DialogPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<DialogPane prefHeight="300.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ua.nure.blockchainservice.controller.AddNewTransactionController">
   <content>
      <AnchorPane prefHeight="200.0" prefWidth="200.0">
         <children>
            <TextField fx:id="toAddress" layoutX="67.0" layoutY="149.0" />
            <Label layoutX="352.0" layoutY="131.0" text="Amount:" AnchorPane.rightAnchor="104.5">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <Label layoutX="142.0" layoutY="52.0" text="Add New Transaction">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label layoutX="101.0" layoutY="130.0" text="To Address:" AnchorPane.leftAnchor="101.0">
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TextField fx:id="value" layoutX="280.0" layoutY="149.0" />
            <Button layoutX="67.0" layoutY="217.0" mnemonicParsing="false" onAction="#createNewTransaction" prefHeight="26.0" prefWidth="371.0" text="Send Transaction" textFill="#00e134">
               <font>
                  <Font name="System Bold" size="16.0" />
               </font>
            </Button>
         </children>
      </AnchorPane>
   </content>
</DialogPane>
